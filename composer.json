{
	"name": "woocommerce/snapchat-for-woocommerce",
	"description": "Snapchat for WooCommerce",
	"license": "GPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/woocommerce/snapchat-for-woocommerce"
	},
	"autoload": {
		"psr-4": {
			"SnapchatForWoocommerce\\": "includes/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.0",
		"automattic/jetpack-autoloader": "^2",
		"woocommerce/woocommerce-sniffs": "^1.0"
	},
	"config": {
		"allow-plugins": {
			"automattic/jetpack-autoloader": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
