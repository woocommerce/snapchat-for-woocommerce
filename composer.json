{
	"name": "woocommerce/snapchat-for-woocommerce",
	"description": "Snapchat for WooCommerce",
	"license": "GPL-3.0-or-later",
	"autoload": {
		"psr-4": {
			"SnapchatForWooCommerce\\": "includes/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.0",
		"automattic/jetpack-autoloader": "^2",
		"woocommerce/woocommerce-sniffs": "^1.0",
		"sirbrillig/phpcs-changed": "^2.11",
		"yoast/phpunit-polyfills": "^4.0",
		"dg/bypass-finals": "^1.9"
	},
	"archive": {
		"exclude": [
			"!/assets",
			"!/build",
			"!/languages",
			"node_modules",
			"woocommerce-eu-vat-number.zip",
			"README.md",
			"composer.json",
			"composer.lock",
			"package.json",
			"package-lock.json",
			"phpcs.xml.dist",
			"phpcs-compat.xml.dist",
			"webpack.config.js",
			".*"
		]
	},
	"config": {
		"allow-plugins": {
			"automattic/jetpack-autoloader": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
